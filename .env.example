# Project Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# PySpark Configuration
# ============================================
SPARK_LOCAL_IP=127.0.0.1
SPARK_MASTER=local[*]
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MEMORY=2g

# ============================================
# DuckDB Configuration
# ============================================
DUCKDB_PATH=./data/processed/analytics.duckdb
DUCKDB_READONLY=False

# ============================================
# Apache Airflow Configuration
# ============================================
AIRFLOW_HOME=./airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:///./airflow/airflow.db
AIRFLOW__CORE__DAGS_FOLDER=./airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__UNIT_TEST_MODE=False
AIRFLOW__CORE__PARALLELISM=8
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=1

# ============================================
# dbt Configuration
# ============================================
DBT_PROJECT_DIR=./dbt/analytics
DBT_PROFILES_DIR=./dbt/analytics
DBT_TARGET=dev

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# ============================================
# Data Pipeline Configuration
# ============================================
PIPELINE_SCHEDULE_INTERVAL=0 2 * * *
PIPELINE_START_DATE=2024-01-01
PIPELINE_TIMEZONE=UTC

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
AIRFLOW_ALERT_EMAIL=admin@datapipeline.com

# ============================================
# Power BI Configuration
# ============================================
POWERBI_WORKSPACE_ID=your-workspace-id
POWERBI_REPORT_ID=your-report-id

# ============================================
# Development Settings
# ============================================
DEBUG=False
ENVIRONMENT=local
